                f'{val:.3f}', ha='center', fontsize=9)
ax_rec.spines[['top','right']].set_visible(False)
ax_rec.grid(axis='y', alpha=0.2)

# Metrics heatmap
ax_heat = fig.add_subplot(gs[1, 1])
heat_data = metrics_df.set_index('Model')[['Accuracy','Precision','Recall','F1 Score','ROC-AUC']]
sns.heatmap(heat_data, annot=True, fmt='.3f', cmap='YlGn', ax=ax_heat,
