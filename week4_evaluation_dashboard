# ── 6. Patient Risk Profile Export (for Tableau / Power BI) ──────────────────

risk_df = X_test.copy().reset_index(drop=True)
risk_df['actual_label'] = y_test.reset_index(drop=True).map({0:'Not CKD', 1:'CKD'})
risk_df['lr_prediction'] = pd.Series(lr_pred).map({0:'Not CKD', 1:'CKD'})
risk_df['rf_prediction'] = pd.Series(rf_pred).map({0:'Not CKD', 1:'CKD'})
risk_df['lr_risk_score'] = lr_proba.round(4)
risk_df['rf_risk_score'] = rf_proba.round(4)
risk_df['ensemble_risk_score'] = ((lr_proba + rf_proba) / 2).round(4)
risk_df['risk_tier'] = pd.cut(
    risk_df['ensemble_risk_score'],
    bins=[0, 0.33, 0.66, 1.0],
    labels=['Low', 'Medium', 'High']
)

# decode categorical columns back for readability
cat_map = {
    'red_blood_cells': {0: 'abnormal', 1: 'normal'},
    'pus_cell': {0: 'abnormal', 1: 'normal'},
    'pus_cell_clumps': {0: 'notpresent', 1: 'present'},
    'bacteria': {0: 'notpresent', 1: 'present'},
    'hypertension': {0: 'no', 1: 'yes'},
    'diabetes_mellitus': {0: 'no', 1: 'yes'},
    'coronary_artery_disease': {0: 'no', 1: 'yes'},
    'appetite': {0: 'good', 1: 'poor'},
    'pedal_edema': {0: 'no', 1: 'yes'},
    'anemia': {0: 'no', 1: 'yes'},
}
for col, mapping in cat_map.items():
    if col in risk_df.columns:
        risk_df[col] = risk_df[col].map(mapping)

risk_df.to_csv('patient_risk_profiles.csv', index=False)
print("\nRisk profiles exported: patient_risk_profiles.csv")
print("Columns:", risk_df.columns.tolist())

print("\nRisk tier distribution:")
print(risk_df['risk_tier'].value_counts().to_string())

